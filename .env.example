# ============================================================================
# XF-AI-Agent 环境配置示例文件
# ============================================================================
# 说明：这是环境变量配置的示例文件
# 使用方法：复制此文件为 .env 并填入真实的配置值
# 注意：生产环境使用前请修改所有默认密钥和密码
# ============================================================================

# ============ 核心 API 密钥 ============
# Google Gemini API 密钥 (https://makersuite.google.com/app/apikey)
GOOGLE_API_KEY=your_google_api_key_here

# OpenRouter API 配置 (https://openrouter.ai/)
OPENROUTER_API_KEY=sk-or-v1-your_openrouter_key_here
OPENROUTER_API_BASE=https://openrouter.ai/api/v1

# 硅基流动 API 配置 (https://cloud.siliconflow.cn/)
SILICONFLOW_API_KEY=sk-your_siliconflow_key_here
SILICONFLOW_API_BASE=https://api.siliconflow.cn/v1

# ============ 模型配置 ============
# 默认使用的大语言模型
DEFAULT_MODEL=qwen3:8b

# 可用的大语言模型列表（逗号分隔）
AVAILABLE_MODELS=deepseek-r1:8b,qwen3:8b,gemma2:2b,llama3.1:latest

# 支持的模型类型（逗号分隔）
SUPPORTED_MODEL_TYPES=ollama,openRouter,chat,zhipu,qwen

# Embedding 模型配置
EMBEDDING_MODEL=bge-m3:latest
AVAILABLE_EMBEDDING_MODELS=bge-m3:latest,nomic-embed-text:latest,mxbai-embed-large:latest,bge-large-en-v1.5:latest,bge-large-zh-v1.5:latest
EMBEDDING_BASE_URL=http://localhost:11434

# ============ 数据库配置 ============
# MySQL 数据库配置
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_mysql_password_here
MYSQL_DATABASE=xf-ai-agent

# MongoDB 主配置
MONGODB_URL=mongodb://username:password@host:port/database_name
MONGODB_DB_NAME=xf-ai-agent

# MongoDB 连接池配置
MONGODB_MAX_POOL_SIZE=50
MONGODB_MIN_POOL_SIZE=10
MONGODB_SOCKET_TIMEOUT_MS=60000
MONGODB_MAX_IDLE_TIME_MS=60000
MONGODB_HEARTBEAT_FREQUENCY_MS=20000
MONGODB_SERVER_SELECTION_TIMEOUT_MS=5000
MONGODB_CONNECT_TIMEOUT_MS=10000

# Redis 配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=your_redis_password
REDIS_DECODE_RESPONSES=0
REDIS_SOCKET_TIMEOUT=60
REDIS_SOCKET_CONNECT_TIMEOUT=60
REDIS_TTL=3600

# ============ RAG 检索配置 ============
# 向量存储配置
VECTOR_STORE_PATH=faiss_index
DEFAULT_SIMILARITY_THRESHOLD=0.7
MAX_RETRIEVED_DOCS=3

# 文本分割配置
DEFAULT_CHUNK_SIZE=1000
DEFAULT_CHUNK_OVERLAP=200
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
SEPARATORS=\n\n,\n,。,！,？,.,!,?, ,

# ============ 聊天配置 ============
# 对话历史配置
HISTORY_FILE=chat_history.json
MAX_HISTORY_TURNS=5

# 确认关键词（逗号分隔）
CONFIRM_KEYWORDS=ok,好的,好,行,嗯,可以,done,确认,完成,没问题,yes,好嘞,没问题啦

# ============ 安全配置 ============
# JWT 密钥配置（生产环境必须生成新的安全密钥）
JWT_SECRET_KEY=your_jwt_secret_key_here_must_be_changed_in_production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# 密码策略配置
PASSWORD_MIN_LENGTH=8
PASSWORD_STRENGTH_CHECK=true
BCRYPT_ROUNDS=12

# ============ 第三方服务配置 ============
# 高德地图 API 密钥
AMAP_API_KEY=your_amap_api_key_here

# 和风天气 API 配置 (https://console.qweather.com/)
HF_API_KEY=your_qweather_api_key_here
HF_LOCATION_URL=https://geoapi.qweather.com/v2/city/lookup
HF_REAL_TIME_URL=https://devapi.qweather.com/v7/weather/now
HF_INDICES_URL=https://devapi.qweather.com/v7/indices/1d?type=1,2&location={location}

# Tavily 搜索 API 配置 (https://app.tavily.com/home)
TAVILY_API_KEY=your_tavily_api_key_here
TAVILY_MAX_RESULTS=5

# 云柚代理配置
YY_BASE_URL=http://127.0.0.1:8089/

# ============ 开发工具配置 ============
# LangSmith 配置 (https://smith.langchain.com/)
LANGSMITH_TRACING=true
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_API_KEY=your_langsmith_api_key_here
LANGSMITH_PROJECT=xf-ai-agent

# ============================================================================
# 备用配置（如需要可取消注释）
# ============================================================================

# 备用 LangSmith API Key
# LANGSMITH_API_KEY=your_backup_langsmith_key_here