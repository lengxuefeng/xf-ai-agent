GOOGLE_API_KEY="AIzaSyCgeDUz1EpyqWK7wvoFwVUE8sA57egdJ60"

# 1. 文件路径
VECTOR_STORE_PATH="faiss_index"
# 对话历史文件
HISTORY_FILE="chat_history.json"

# 2. 模型配置
DEFAULT_MODEL="qwen3:8b"
AVAILABLE_MODELS=["deepseek-r1:8b", "qwen3:8b", "gemma2:2b", "llama3.1:latest"]

# embedding 模型名称
EMBEDDING_MODEL="bge-m3:latest"
AVAILABLE_EMBEDDING_MODELS=["bge-m3:latest", "nomic-embed-text:latest", "mxbai-embed-large:latest",
                              "bge-large-en-v1.5:latest", "bge-large-zh-v1.5:latest"]
# embedding 模型基础url,默认ollama地址
EMBEDDING_BASE_URL="http://localhost:11434"

# 3. RAG配置
DEFAULT_SIMILARITY_THRESHOLD=0.7
DEFAULT_CHUNK_SIZE=1000
DEFAULT_CHUNK_OVERLAP=200
MAX_RETRIEVED_DOCS=3

# 4. 高德地图MCP key
AMAP_API_KEY="d3099bc08ff2f92edad48d2537984adc"

# 5. LangChain配置
# 文本分割器chunk大小
CHUNK_SIZE=1000
# 文本分割器重叠长度
CHUNK_OVERLAP=200
# 文本分割器分隔符
SEPARATORS=["\n\n", "\n", "。", "！", "？", ".", "!", "?", " ", ""]

# 6. 对话历史配置
MAX_HISTORY_TURNS=5

# 目前项目支持的模型类型
SUPPORTED_MODEL_TYPES=["ollama","openRouter","chat","zhipu","qwen"]

# MongoDB 配置
MONGODB_URL=mongodb://localhost:27017
MONGODB_DB_NAME=xf-ai-agent
